{
  "expo": {
    "name": "Switchback",
    "slug": "expedition-conditioning",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expedition",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "light",
    "backgroundColor": "#F2ECDC",
    "ios": {
      "bundleIdentifier": "com.tommi.expeditionconditioning",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tommi.expeditionconditioning",
      "adaptiveIcon": {
        "backgroundColor": "#F2ECDC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2ECDC",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Switchback uses the camera to scan food barcodes for the fuel log.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Switchback reads bodyweight, resting heart rate and sleep to drive fuel targets and recovery signals.",
          "NSHealthUpdateUsageDescription": "Switchback saves finished strength sessions and rucks to Apple Health.",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "780144bc-7c35-4df1-9f6a-0665f41b591c"
      }
    },
    "owner": "tommyg5121",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/780144bc-7c35-4df1-9f6a-0665f41b591c"
    }
  }
}
